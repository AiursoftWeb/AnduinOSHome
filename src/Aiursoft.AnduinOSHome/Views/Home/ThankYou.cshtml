@* ── Phase 1: Create Installation Media ── *@
<section class="py-6 bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["Phase 1"]</span>
            <h2 class="h1">@Localizer["Create Installation Media"]</h2>
            <p class="text-muted fs-lg">@Localizer["Verify your download and create a bootable USB drive."]</p>
        </div>

        @* Checksum Verification *@
        <div class="row mb-5">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start">
                            <div class="d-inline-flex align-items-center justify-content-center rounded-3 bg-primary bg-opacity-10 me-3" style="width: 48px; height: 48px; min-width: 48px;">
                                <i data-lucide="fingerprint" class="text-primary" style="width: 22px; height: 22px;"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h4 class="mt-0">@Localizer["1. Verify the checksum"]</h4>
                                <p class="fs-lg">@Localizer["After downloading the ISO file, verify its integrity to ensure it has not been tampered with."]</p>
                                <div class="row align-items-center g-4">
                                    <div class="col-lg-4">
                                        <div class="bg-dark rounded-3 p-3 mb-3">
                                            <code class="text-white" style="font-size: 0.9rem;">sha256sum ./AnduinOS.iso</code>
                                        </div>
                                        <p class="fs-lg mb-0">
                                            @Localizer["Compare the output with the"]
                                            <a href="https://cf.anduinos.com/AnduinOS-2.0.1-amd64.sha256">@Localizer["official SHA256 checksum"]</a>@Localizer[". If they match, your ISO is valid."]
                                        </p>
                                    </div>
                                    <div class="col-lg-8 text-center">
                                        <img src="~/images/checksum.webp" alt="@Localizer["Verify ISO checksum"]" class="img-fluid rounded-3" style="max-height: 340px;" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Platform Tabs *@
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-bottom pt-4 pb-3">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h4 class="mb-0">@Localizer["2. Create a bootable USB drive"]</h4>
                    <div class="d-flex gap-2 flex-wrap" role="group" id="platform-tabs">
                        <button class="btn btn-outline-primary rounded-pill active" type="button"
                                onclick="switchPlatform('windows')">
                            <i class="fab fa-windows me-1"></i>Windows
                        </button>
                        <button class="btn btn-outline-primary rounded-pill" type="button"
                                onclick="switchPlatform('linux')">
                            <i class="fab fa-linux me-1"></i>Linux
                        </button>
                        <button class="btn btn-outline-primary rounded-pill" type="button"
                                onclick="switchPlatform('macos')">
                            <i class="fab fa-apple me-1"></i>macOS
                        </button>
                        <button class="btn btn-outline-primary rounded-pill" type="button"
                                onclick="switchPlatform('ventoy')">
                            <i data-lucide="usb" style="width:14px;height:14px;" class="me-1"></i>Ventoy
                        </button>
                    </div>
                    <script>
                        function switchPlatform(name) {
                            document.querySelectorAll('.platform-panel').forEach(p => p.classList.remove('show'));
                            document.getElementById('panel-' + name).classList.add('show');
                            document.querySelectorAll('#platform-tabs .btn').forEach(b => b.classList.remove('active'));
                            event.target.closest('button').classList.add('active');
                        }
                    </script>
                </div>
            </div>
            <div class="card-body p-4">
                @* Windows Panel *@
                <div class="collapse show platform-panel" id="panel-windows">
                    <div class="row align-items-center g-4">
                        <div class="col-lg-6">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <span class="badge bg-primary bg-opacity-10 text-primary px-2 py-1">Rufus</span>
                                <span class="text-muted small">@Localizer["Free, open-source USB flashing tool"]</span>
                            </div>
                            <p class="text-muted mb-3">@Localizer["We recommend using Rufus to create the bootable USB drive. Make sure to select"] <strong>@Localizer["dd mode"]</strong> @Localizer["instead of ISO mode."]</p>
                            <div class="bg-warning-subtle border-start border-4 border-warning rounded-2 p-3 mb-3">
                                <p class="fw-semibold mb-1 small">⚠️ @Localizer["Use dd mode, not ISO mode!"]</p>
                                <p class="mb-0 small text-muted">@Localizer["ISO mode may cause AnduinOS to fail to boot."]</p>
                            </div>
                            <div class="d-flex gap-2 flex-wrap">
                                <a href="https://rufus.ie/" class="btn btn-primary btn-sm btn-pill" target="_blank">
                                    <i data-lucide="download" style="width: 14px; height: 14px;" class="me-1"></i>@Localizer["Download Rufus"]
                                </a>
                                <a href="https://docs.anduinos.com/Install/Burn-A-USB-Stick.html" class="btn btn-outline-primary btn-sm btn-pill">
                                    @Localizer["Full Guide"] <i data-lucide="arrow-right" style="width: 14px; height: 14px;"></i>
                                </a>
                            </div>
                        </div>
                        <div class="col-lg-6 text-center">
                            <img src="~/images/rufus.webp" alt="Rufus" class="img-fluid rounded-3" style="max-height: 280px;" loading="lazy" />
                        </div>
                    </div>
                </div>

                @* Linux Panel *@
                <div class="collapse platform-panel" id="panel-linux">
                    <div class="row align-items-center g-4">
                        <div class="col-lg-6">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <span class="badge bg-success bg-opacity-10 text-success px-2 py-1">Impression</span>
                                <span class="text-muted small">@Localizer["Simple, modern ISO flashing tool"]</span>
                            </div>
                            <p class="text-muted mb-3">@Localizer["Impression is the most user-friendly way to flash the ISO on Linux. Install it via Flatpak:"]</p>
                            <div class="d-flex gap-2 flex-wrap mb-3">
                                <a href="https://flathub.org/en/apps/io.gitlab.adhami3310.Impression" class="btn btn-primary btn-sm btn-pill" target="_blank">
                                    <i data-lucide="download" style="width: 14px; height: 14px;" class="me-1"></i>@Localizer["Get Impression on Flathub"]
                                </a>
                                <a href="https://docs.anduinos.com/Install/Burn-A-USB-Stick.html" class="btn btn-outline-primary btn-sm btn-pill">
                                    @Localizer["Full Guide"] <i data-lucide="arrow-right" style="width: 14px; height: 14px;"></i>
                                </a>
                            </div>
                            <p class="text-muted small mb-2">@Localizer["Or use the command line:"]</p>
                            <div class="bg-dark rounded-3 p-2 mb-0">
                                <code class="text-white" style="font-size: 0.8rem;">sudo dd if=./AnduinOS.iso of=&lt;device&gt; status=progress oflag=sync bs=4M</code>
                            </div>
                        </div>
                        <div class="col-lg-6 text-center">
                            <img src="~/images/impression.webp" alt="Impression" class="img-fluid rounded-3" style="max-height: 280px;" loading="lazy" />
                        </div>
                    </div>
                </div>

                @* macOS Panel *@
                <div class="collapse platform-panel" id="panel-macos">
                    <div class="row align-items-center g-4">
                        <div class="col-lg-6">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <span class="badge bg-info bg-opacity-10 text-info px-2 py-1">BalenaEtcher</span>
                                <span class="text-muted small">@Localizer["Cross-platform, safe ISO flasher"]</span>
                            </div>
                            <p class="text-muted mb-3">@Localizer["BalenaEtcher is a cross-platform graphical tool that makes flashing ISO images simple and safe."]</p>
                            <ol class="small text-muted mb-3">
                                <li>@Localizer["Download and install"] <a href="https://etcher.balena.io/">BalenaEtcher</a>.</li>
                                <li>@Localizer["Click \"Flash from file\" and select the AnduinOS ISO."]</li>
                                <li>@Localizer["Select your target USB drive and click \"Flash!\"."]</li>
                            </ol>
                            <div class="d-flex gap-2 flex-wrap">
                                <a href="https://etcher.balena.io/" class="btn btn-primary btn-sm btn-pill" target="_blank">
                                    <i data-lucide="download" style="width: 14px; height: 14px;" class="me-1"></i>@Localizer["Download Etcher"]
                                </a>
                                <a href="https://docs.anduinos.com/Install/Burn-A-USB-Stick.html" class="btn btn-outline-primary btn-sm btn-pill">
                                    @Localizer["Full Guide"] <i data-lucide="arrow-right" style="width: 14px; height: 14px;"></i>
                                </a>
                            </div>
                        </div>
                        <div class="col-lg-6 text-center d-none d-lg-block">
                            <div class="bg-light rounded-4 d-inline-flex align-items-center justify-content-center" style="width: 120px; height: 120px;">
                                <i class="fab fa-apple fa-4x text-dark"></i>
                            </div>
                        </div>
                    </div>
                </div>

                @* Ventoy Panel *@
                <div class="collapse platform-panel" id="panel-ventoy">
                    <div class="row align-items-center g-4">
                        <div class="col-lg-6">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <span class="badge bg-warning bg-opacity-10 text-warning px-2 py-1">Ventoy</span>
                                <span class="text-muted small">@Localizer["Multi-ISO, reusable USB solution"]</span>
                            </div>
                            <p class="text-muted mb-3">@Localizer["If you frequently install operating systems, Ventoy lets you keep your USB drive usable for regular storage while still being bootable. Simply copy the ISO file onto the drive and boot."]</p>
                            <ol class="small text-muted mb-3">
                                <li>@Localizer["Install"] <a href="https://www.ventoy.net/">Ventoy</a> @Localizer["to your USB drive."]</li>
                                <li>@Localizer["Copy the AnduinOS ISO onto the drive like a regular file."]</li>
                                <li>@Localizer["Boot from USB and select the ISO from Ventoy's menu."]</li>
                            </ol>
                            <p class="small text-success mb-3 fw-semibold">@Localizer["No repeated flashing or erasing needed!"]</p>
                            <div class="d-flex gap-2 flex-wrap">
                                <a href="https://www.ventoy.net/" class="btn btn-primary btn-sm btn-pill" target="_blank">
                                    <i data-lucide="download" style="width: 14px; height: 14px;" class="me-1"></i>@Localizer["Download Ventoy"]
                                </a>
                                <a href="https://docs.anduinos.com/Install/Burn-A-USB-Stick.html" class="btn btn-outline-primary btn-sm btn-pill">
                                    @Localizer["Full Guide"] <i data-lucide="arrow-right" style="width: 14px; height: 14px;"></i>
                                </a>
                            </div>
                        </div>
                        <div class="col-lg-6 text-center d-none d-lg-block">
                            <div class="bg-light rounded-4 d-inline-flex align-items-center justify-content-center" style="width: 120px; height: 120px;">
                                <i data-lucide="usb" style="width: 56px; height: 56px;" class="text-warning"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ── Phase 2: Install AnduinOS ── *@
<section class="py-6 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["Phase 2"]</span>
            <h2 class="h1">@Localizer["Install AnduinOS"]</h2>
            <p class="text-muted fs-lg">@Localizer["Boot from USB and follow the graphical installer."]</p>
        </div>

        <div class="row align-items-center g-5">
            @* Left: Installation steps *@
            <div class="col-lg-6">
                @* Pre-installation tips *@
                <div class="bg-white border-start border-4 border-primary rounded-2 p-3 mb-4 shadow-sm">
                    <p class="fw-semibold mb-2">💡 @Localizer["Optional Pre-installation Steps"]</p>
                    <ul class="mb-0 small">
                        <li><strong>@Localizer["Secure Boot"]</strong> — <a href="https://docs.anduinos.com/Install/First-Boot-For-Secure-Boot.html">@Localizer["Enable it in BIOS before booting"]</a></li>
                        <li><strong>@Localizer["NVMe SSD?"]</strong> — <a href="https://docs.anduinos.com/Install/Change-NVME-LBA-Size.html">@Localizer["Change LBA size to 4K for optimal performance"]</a></li>
                        <li><strong>@Localizer["Dual Boot?"]</strong> — <a href="https://docs.anduinos.com/Install/Dual-Boot-With-Windows.html">@Localizer["Read the dual-boot guide first"]</a></li>
                    </ul>
                </div>

                @* Boot from USB *@
                <h4 class="fw-bold mb-2">@Localizer["Boot from USB"]</h4>
                <p class="text-muted">@Localizer["Common boot menu keys:"] <strong>F12, F11, Esc, F10,</strong> @Localizer["or"] <strong>@Localizer["Vol Down + Power"]</strong></p>
                <ol class="mb-4">
                    <li>@Localizer["Insert the USB drive and power on your computer."]</li>
                    <li>@Localizer["Press your manufacturer's boot menu key immediately."]</li>
                    <li>@Localizer["Select the USB drive in the boot menu."]</li>
                    <li>@Localizer["In GRUB, select your language and choose"] <strong>@Localizer["Install AnduinOS"]</strong>.</li>
                </ol>
            </div>

            @* Right: Installer screenshot *@
            <div class="col-lg-6 text-center">
                <div class="card border-0 shadow-lg">
                    <div class="card-body p-3">
                        <img src="~/images/run_installer.webp"
                             alt="@Localizer["AnduinOS Installer"]"
                             class="img-fluid rounded-3"
                             loading="lazy" />
                    </div>
                    <div class="card-footer bg-light border-0 text-muted small py-2">
                        <i data-lucide="info" style="width: 14px; height: 14px;" class="me-1"></i>
                        @Localizer["The AnduinOS graphical installer — straightforward and guided."]
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ── Phase 3: First Boot Setup ── *@
<section class="py-6 bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["Phase 3"]</span>
            <h2 class="h1">@Localizer["After Installation"]</h2>
            <p class="text-muted fs-lg">@Localizer["First things to set up when you boot into AnduinOS."]</p>
        </div>

        <div class="row g-4">
            @* Secure Boot *@
            <div class="col-md-4 col-sm-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="d-inline-flex align-items-center justify-content-center rounded-3 bg-success bg-opacity-10" style="width: 48px; height: 48px; min-width: 48px;">
                                <i data-lucide="shield-check" class="text-success" style="width: 22px; height: 22px;"></i>
                            </div>
                            <h5 class="mb-0">@Localizer["Secure Boot Enrollment"]</h5>
                        </div>
                        <img src="~/images/set-secure-boot-password.webp" alt="@Localizer["Secure Boot"]" class="img-fluid rounded-3 mb-3" style="width: 100%; height: 120px; object-fit: cover;" loading="lazy" />
                        <p class="text-muted small mb-3">@Localizer["Complete the MOK enrollment on first boot to enable third-party drivers like NVIDIA and Xbox controllers."]</p>
                        <a href="https://docs.anduinos.com/Install/First-Boot-For-Secure-Boot.html" class="btn btn-outline-primary btn-sm btn-pill stretched-link">
                            @Localizer["Secure Boot Guide"] <i data-lucide="arrow-right" style="width: 14px; height: 14px;"></i>
                        </a>
                    </div>
                </div>
            </div>

            @* Switch Language *@
            <div class="col-md-4 col-sm-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="d-inline-flex align-items-center justify-content-center rounded-3 bg-primary bg-opacity-10" style="width: 48px; height: 48px; min-width: 48px;">
                                <i data-lucide="languages" class="text-primary" style="width: 22px; height: 22px;"></i>
                            </div>
                            <h5 class="mb-0">@Localizer["Switch Language"]</h5>
                        </div>
                        <img src="~/images/settings-region-language.webp" alt="@Localizer["Language Settings"]" class="img-fluid rounded-3 mb-3" style="width: 100%; height: 120px; object-fit: cover;" loading="lazy" />
                        <p class="text-muted small mb-3">@Localizer["Change the system language, regional formats, and add input methods like Chinese Pinyin or Japanese Anthy."]</p>
                        <a href="https://docs.anduinos.com/Install/Switch-To-Your-Language.html" class="btn btn-outline-primary btn-sm btn-pill stretched-link">
                            @Localizer["Language Guide"] <i data-lucide="arrow-right" style="width: 14px; height: 14px;"></i>
                        </a>
                    </div>
                </div>
            </div>

            @* Update System *@
            <div class="col-md-4 col-sm-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="d-inline-flex align-items-center justify-content-center rounded-3 bg-info bg-opacity-10" style="width: 48px; height: 48px; min-width: 48px;">
                                <i data-lucide="refresh-cw" class="text-info" style="width: 22px; height: 22px;"></i>
                            </div>
                            <h5 class="mb-0">@Localizer["Update Your System"]</h5>
                        </div>
                        <img src="~/images/app-store-updates.webp" alt="@Localizer["System Updates"]" class="img-fluid rounded-3 mb-3" style="width: 100%; height: 120px; object-fit: cover;" loading="lazy" />
                        <p class="text-muted small mb-3">@Localizer["Security patches are applied automatically. For feature updates, use the App Store's offline update mechanism."]</p>
                        <a href="https://docs.anduinos.com/Install/Update-Your-System.html" class="btn btn-outline-primary btn-sm btn-pill stretched-link">
                            @Localizer["Update Guide"] <i data-lucide="arrow-right" style="width: 14px; height: 14px;"></i>
                        </a>
                    </div>
                </div>
            </div>

            @* Firewall *@
            <div class="col-md-4 col-sm-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="d-inline-flex align-items-center justify-content-center rounded-3 bg-danger bg-opacity-10" style="width: 48px; height: 48px; min-width: 48px;">
                                <i data-lucide="shield" class="text-danger" style="width: 22px; height: 22px;"></i>
                            </div>
                            <h5 class="mb-0">@Localizer["Enable Firewall"]</h5>
                        </div>
                        <img src="~/images/ufwall-gtk-main.webp" alt="@Localizer["Firewall"]" class="img-fluid rounded-3 mb-3" style="width: 100%; height: 120px; object-fit: cover;" loading="lazy" />
                        <p class="text-muted small mb-3">@Localizer["UFW is disabled by default (no open ports = no risk). Enable it via the Welcome Center or graphical Firewall app when needed."]</p>
                        <a href="https://docs.anduinos.com/Install/Enable-Firewall.html" class="btn btn-outline-primary btn-sm btn-pill stretched-link">
                            @Localizer["Firewall Guide"] <i data-lucide="arrow-right" style="width: 14px; height: 14px;"></i>
                        </a>
                    </div>
                </div>
            </div>

            @* Drivers *@
            <div class="col-md-4 col-sm-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="d-inline-flex align-items-center justify-content-center rounded-3 bg-warning bg-opacity-10" style="width: 48px; height: 48px; min-width: 48px;">
                                <i data-lucide="cpu" class="text-warning" style="width: 22px; height: 22px;"></i>
                            </div>
                            <h5 class="mb-0">@Localizer["Install Drivers"]</h5>
                        </div>
                        <img src="~/images/anduinos-oobe-nvidia.webp" alt="@Localizer["Drivers"]" class="img-fluid rounded-3 mb-3" style="width: 100%; height: 120px; object-fit: cover;" loading="lazy" />
                        <p class="text-muted small mb-3">@Localizer["Use the Welcome Center to install NVIDIA drivers, Xbox controller support, and other hardware drivers with one click."]</p>
                        <a href="https://docs.anduinos.com/Install/Install-Drivers.html" class="btn btn-outline-primary btn-sm btn-pill stretched-link">
                            @Localizer["Drivers Guide"] <i data-lucide="arrow-right" style="width: 14px; height: 14px;"></i>
                        </a>
                    </div>
                </div>
            </div>

            @* Backup *@
            <div class="col-md-4 col-sm-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="d-inline-flex align-items-center justify-content-center rounded-3 bg-secondary bg-opacity-10" style="width: 48px; height: 48px; min-width: 48px;">
                                <i data-lucide="hard-drive" class="text-secondary" style="width: 22px; height: 22px;"></i>
                            </div>
                            <h5 class="mb-0">@Localizer["Setup Backup"]</h5>
                        </div>
                        <img src="~/images/deja-dup-backups.webp" alt="@Localizer["Backup"]" class="img-fluid rounded-3 mb-3" style="width: 100%; height: 120px; object-fit: cover;" loading="lazy" />
                        <p class="text-muted small mb-3">@Localizer["Use Deja Dup for automated, encrypted backups to an external drive or cloud storage. Set it once, forget about it."]</p>
                        <a href="https://docs.anduinos.com/Install/Backup-And-Restore.html" class="btn btn-outline-primary btn-sm btn-pill stretched-link">
                            @Localizer["Backup Guide"] <i data-lucide="arrow-right" style="width: 14px; height: 14px;"></i>
                        </a>
